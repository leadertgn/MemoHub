# Copier ce fichier en .env et remplir les valeurs réelles

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require

# Authentication
SECRET_KEY=your-secret-key-here

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudinary (Image/File Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Notifications (Brevo - formerly Sendinblue)
# Get API key from: https://brevo.com/
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=notifications@leadertgn.me
BREVO_SENDER_NAME=MemoHub

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OAuth Redirect URIs et CORS
ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/callback,https://memohub.africa/auth/callback
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://memohub.africa

# Environment
ENVIRONMENT=development
