# Copier ce fichier en .env et remplir les valeurs réelles

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Railway: défini automatiquement via variable Railway "DATABASE_URL"
# Local: postgresql+psycopg2://user:password@localhost:5432/memohub
DATABASE_URL=postgresql+psycopg2://user:password@host/dbname?sslmode=require

# ===========================================
# JWT Configuration
# ===========================================
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# Google OAuth2
# ===========================================
# Créer un projet Google Cloud : https://console.cloud.google.com/
# Activer OAuth2 API
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs autorisées pour redirect OAuth (séparées par des virgules)
# LOCAL: http://localhost:5173/auth/callback
# PROD:  https://memohub.leadertgn.me/auth/callback
ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/callback,https://memohub.leadertgn.me/auth/callback

# Origins autorisées pour CORS (séparées par des virgules)
# LOCAL: http://localhost:5173
# PROD:  https://memohub.leadertgn.me
ALLOWED_ORIGINS=http://localhost:5173,https://memohub.leadertgn.me

# ===========================================
# Cloudinary (Stockage fichiers)
# ===========================================
# Créer un compte : https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ===========================================
# Brevo/Sendinblue (Emails)
# ===========================================
# Créer compte : https://www.brevo.com/
BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=notifications@leadertgn.me
BREVO_SENDER_NAME=MemoHub

# ===========================================
# Environment
# ===========================================
# "development" ou "production"
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
