# --- CONFIGURATION GÉNÉRALE ---
ENVIRONMENT=development
SECRET_KEY=générez-une-clé-très-longue-et-secrète-ici-32-caractères-min
DATABASE_URL=postgresql://user:password@localhost:5432/memohub

# --- DOMAINES ET CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_REDIRECT_URIS=http://localhost:5173/auth/callback,http://127.0.0.1:5173/auth/callback
FRONTEND_URL=http://localhost:5173

# --- GOOGLE OAUTH2 ---
GOOGLE_CLIENT_ID=votre-id-google-apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-secret-google

# --- CLOUDINARY (Stockage PDF) ---
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# --- BREVO (Notifications Email) ---
BREVO_API_KEY=votre-cle-api-brevo
BREVO_SENDER_EMAIL=contact@memohub.com
BREVO_SENDER_NAME=MemoHub

# --- REDIS (Rate Limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- ANTI-SLEEP (Render uniquement) ---
# Laisser vide en local. En prod sur Render, mettre l'URL publique de l'API.
# Exemple: https://memohub-api.onrender.com
BACKEND_URL=